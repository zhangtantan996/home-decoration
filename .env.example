# ==========================================
# 家装设计平台 - 环境变量配置示例
# ==========================================
#
# 使用说明:
# 1. 复制此文件为 .env
# 2. 根据实际环境修改配置值
# 3. .env 文件已在 .gitignore 中，不会提交到仓库
#

# ==========================================
# 应用环境
# ==========================================
APP_ENV=local  # local, docker, production

# ==========================================
# 服务器配置
# ==========================================
SERVER_HOST=0.0.0.0
SERVER_PORT=8080
SERVER_MODE=debug  # debug, release
# 对外访问的 API 基础地址（用于拼接图片/文件完整 URL）
# 生产环境示例: https://api.example.com
SERVER_PUBLIC_URL=http://localhost:8080

# CORS 白名单（多个用逗号分隔）
# 生产环境建议仅放行你的管理后台域名，如: https://admin.example.com
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174

# 通知实时推送（站内通知 WebSocket）
NOTIFICATION_REALTIME_ENABLED=true
NOTIFICATION_WS_MAX_CONN_PER_USER=5
NOTIFICATION_WS_MAX_CONN_PER_IP=50
NOTIFICATION_WS_PING_INTERVAL_SECONDS=30
NOTIFICATION_WS_IDLE_TIMEOUT_SECONDS=90
NOTIFICATION_WS_SEND_BUFFER_SIZE=32

# ==========================================
# 数据库配置 (PostgreSQL)
# ==========================================
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USER=postgres
DATABASE_PASSWORD=your_db_password_here
# 推荐使用 DATABASE_DBNAME（配置项为 database.dbname）
# 命名建议：
# - local: home_decoration
# - test: home_decoration_test
# - staging: home_decoration_staging
# - production: home_decoration
DATABASE_DBNAME=home_decoration
# 兼容旧变量名（二选一即可）
# DATABASE_NAME=home_decoration
DATABASE_SSLMODE=disable

# ==========================================
# Redis 配置
# ==========================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# ==========================================
# JWT 认证配置
# ==========================================
# 重要: 生产环境必须使用强随机字符串!
# 生成方法: openssl rand -base64 64
JWT_SECRET=your_jwt_secret_key_here_please_change_in_production
JWT_EXPIRE_HOUR=8

# ==========================================
# 敏感数据加密 (生产必配)
# ==========================================
# 用于身份证号、银行卡号等敏感字段加密存储（AES-256-GCM）。
# 推荐生成: openssl rand -base64 32
ENCRYPTION_KEY=

# ==========================================
# 日志配置
# ==========================================
LOG_LEVEL=info  # debug, info, warn, error
LOG_FILE=logs/backend.log

# ==========================================
# 管理后台配置
# ==========================================
VITE_API_URL=http://localhost:8080/api/v1
VITE_ENABLE_NOTIFICATION_WS=true

# ==========================================
# 移动端配置
# ==========================================
# React Native Metro bundler
METRO_PORT=8081
ENABLE_NOTIFICATION_WS=true

# ==========================================
# 第三方服务配置
# ==========================================

# 短信服务 (阿里云)
SMS_PROVIDER=mock  # mock | aliyun
SMS_ACCESS_KEY_ID=
SMS_ACCESS_KEY_SECRET=
SMS_SIGN_NAME=
SMS_TEMPLATE_CODE=

# 实名认证（一期二要素）
# local/test 可使用 fake；production 必须接入真实供应商，未配置时支付前实名会失败关闭。
USER_REAL_NAME_VERIFY_PROVIDER=fake  # fake | tencent | aliyun
LICENSE_VERIFY_PROVIDER=manual       # manual | aliyun
ALIYUN_VERIFY_ACCESS_KEY_ID=
ALIYUN_VERIFY_ACCESS_KEY_SECRET=
ALIYUN_PERSON_VERIFY_ENDPOINT=dytnsapi.aliyuncs.com
ALIYUN_PERSON_VERIFY_AUTH_CODE=
ALIYUN_ENTERPRISE_VERIFY_ENDPOINT=dytnsapi.aliyuncs.com
ALIYUN_ENTERPRISE_VERIFY_AUTH_CODE=
TENCENT_REAL_NAME_SECRET_ID=
TENCENT_REAL_NAME_SECRET_KEY=
TENCENT_REAL_NAME_ENDPOINT=https://faceid.tencentcloudapi.com

# 对象存储 (阿里云 OSS)
OSS_ENDPOINT=
OSS_ACCESS_KEY_ID=
OSS_ACCESS_KEY_SECRET=
OSS_BUCKET_NAME=

# 地图服务 (高德地图)
AMAP_API_KEY=

# 支付配置 (支付宝/微信支付)
# 支付宝 Web/H5 一期
# 重要:
# 1. SERVER_PUBLIC_URL 必须是 API 公网地址，例如 https://api.example.com
# 2. ALIPAY_NOTIFY_URL 建议显式配置为 https://api.example.com/api/v1/payments/alipay/notify
# 3. ALIPAY_RETURN_URL_WEB / H5 需与 Web 公开路由一致；如果 Web 部署在 /app，应填写 /app/payments/result
# 4. .env 中建议使用带 \\n 的单行 PEM 字符串；后端会在读取时还原为真实换行
ALIPAY_ENABLED=false
ALIPAY_GATEWAY_URL=https://openapi.alipay.com/gateway.do
ALIPAY_APP_ID=
ALIPAY_APP_PRIVATE_KEY=
ALIPAY_PUBLIC_KEY=
ALIPAY_NOTIFY_URL=
ALIPAY_RETURN_URL_WEB=
ALIPAY_RETURN_URL_H5=
ALIPAY_TIMEOUT_MINUTES=15
ALIPAY_SANDBOX=false

WECHAT_APP_ID=
WECHAT_MCH_ID=
WECHAT_API_KEY=
WECHAT_MINI_APPID=
WECHAT_MINI_SECRET=
WECHAT_H5_APP_ID=
WECHAT_H5_APP_SECRET=
WECHAT_H5_OAUTH_SCOPE=snsapi_base
WECHAT_H5_BIND_TOKEN_EXPIRE_MINUTES=5
# 用于生成/校验微信 OAuth state 的签名密钥（生产环境必须配置强随机字符串）
WECHAT_H5_STATE_SIGNING_SECRET=
WECHAT_H5_BASE_PATH=/app
TARO_APP_ENABLE_NOTIFICATION_WS=true

# ==========================================
# Tinode IM 配置
# ==========================================
# Tinode 即时通讯服务配置

# Tinode 数据库连接 (使用与主应用相同的 PostgreSQL)
# 格式: postgres://用户名:密码@主机:端口/数据库名?sslmode=disable
TINODE_DATABASE_DSN=postgres://postgres:your_db_password_here@home_decor_db_local:5432/tinode?sslmode=disable

# Tinode UID 加密密钥 (16字节 Base64)
# 生成方法: openssl rand -base64 16
TINODE_UID_ENCRYPTION_KEY=

# Tinode Auth Token 密钥 (32字节 Base64)
# 生成方法: openssl rand -base64 32
# 重要: 此密钥必须与后端 JWT_SECRET 保持一致或独立生成
TINODE_AUTH_TOKEN_KEY=

# Tinode API Key Salt (32字节 Base64)
# 生成方法: openssl rand -base64 32
TINODE_API_KEY_SALT=

# 推送通知配置 (可选)
FCM_SERVER_KEY=
APNS_KEY_PASSWORD=

# 旧配置 (已废弃，保留用于兼容)
TINODE_JWT_SECRET=${JWT_SECRET}


# ==========================================
# Docker 环境变量
# ==========================================
# 如果使用 docker-compose.local.yml，以下配置会被使用

COMPOSE_PROJECT_NAME=home_decoration

# 数据库目标安全防呆
# 默认不要设置；仅在明确知道自己在做什么时，才允许临时设置为 1 绕过数据库环境安全检查
ALLOW_UNSAFE_DB_TARGET=0
