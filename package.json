{
  "name": "home-decoration",
  "version": "1.0.0",
  "scripts": {
    "infra": "docker compose up -d db redis",
    "dev:server": "cd server && air",
    "dev:admin": "cd admin && npm run dev",
    "dev:mobile": "cd mobile && npm run web",
    "dev": "npm run infra && concurrently -n \"API,ADMIN,MOBILE\" -c \"magenta,blue,green\" \"npm run dev:server\" \"npm run dev:admin\" \"npm run dev:mobile\"",
    "test:e2e": "npx playwright test"
  },
  "dependencies": {
    "@react-native-community/geolocation": "^3.4.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.57.0",
    "@types/node": "^25.0.3",
    "concurrently": "^9.2.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  }
}