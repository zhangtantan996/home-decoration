{
  "name": "home-decoration",
  "version": "1.0.0",
  "scripts": {
    "infra": "docker compose up -d db redis",
    "dev:server": "cd server && air",
    "dev:admin": "cd admin && npm run dev",
    "dev:mobile": "cd mobile && npm run web",
    "dev:website": "cd website && npx vite --port 5175",
    "dev": "npm run infra && concurrently -n \"API,ADMIN,MOBILE\" -c \"magenta,blue,green\" \"npm run dev:server\" \"npm run dev:admin\" \"npm run dev:mobile\"",
    "test:e2e": "npx playwright test",
    "test:e2e:merchant:onboarding": "npx playwright test tests/e2e/merchant-onboarding-designer-required-fields.test.ts tests/e2e/merchant-onboarding-foreman-required-fields.test.ts tests/e2e/material-shop-onboarding-required-contact.test.ts tests/e2e/publish-visibility-extended-fields.test.ts",
    "test:e2e:merchant:onboarding:list": "npx playwright test --list tests/e2e/merchant-onboarding-designer-required-fields.test.ts tests/e2e/merchant-onboarding-foreman-required-fields.test.ts tests/e2e/material-shop-onboarding-required-contact.test.ts tests/e2e/publish-visibility-extended-fields.test.ts",
    "test:e2e:merchant:smoke": "npx playwright test tests/e2e/merchant-login-unregistered-redirect.test.ts tests/e2e/merchant-entry-register-foreman.test.ts tests/e2e/merchant-onboarding-designer-rule.test.ts tests/e2e/merchant-onboarding-foreman-rule.test.ts tests/e2e/merchant-onboarding-designer-required-fields.test.ts tests/e2e/merchant-onboarding-foreman-required-fields.test.ts tests/e2e/material-shop-onboarding-products-rule.test.ts tests/e2e/material-shop-onboarding-required-contact.test.ts tests/e2e/publish-visibility-threshold.test.ts tests/e2e/publish-visibility-extended-fields.test.ts tests/e2e/merchant-settings-foreman-worktypes.test.ts tests/e2e/merchant-finance-verification.test.ts tests/e2e/merchant-chat-attachments.test.ts",
    "test:e2e:merchant:smoke:list": "npx playwright test --list tests/e2e/merchant-login-unregistered-redirect.test.ts tests/e2e/merchant-entry-register-foreman.test.ts tests/e2e/merchant-onboarding-designer-rule.test.ts tests/e2e/merchant-onboarding-foreman-rule.test.ts tests/e2e/merchant-onboarding-designer-required-fields.test.ts tests/e2e/merchant-onboarding-foreman-required-fields.test.ts tests/e2e/material-shop-onboarding-products-rule.test.ts tests/e2e/material-shop-onboarding-required-contact.test.ts tests/e2e/publish-visibility-threshold.test.ts tests/e2e/publish-visibility-extended-fields.test.ts tests/e2e/merchant-settings-foreman-worktypes.test.ts tests/e2e/merchant-finance-verification.test.ts tests/e2e/merchant-chat-attachments.test.ts",
    "test:identity:acceptance": "node scripts/identity-acceptance-runner.mjs",
    "test:identity:acceptance:api": "npx playwright test -c playwright.identity.config.ts --project=identity-api",
    "test:identity:acceptance:ui": "npx playwright test -c playwright.identity.config.ts --project=identity-admin-ui",
    "test:identity:acceptance:report": "node scripts/identity-acceptance-report.mjs"
  },
  "dependencies": {
    "@react-native-community/geolocation": "^3.4.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.57.0",
    "@types/node": "^25.0.3",
    "concurrently": "^9.2.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  }
}
