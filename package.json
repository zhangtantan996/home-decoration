{
  "name": "home-decoration",
  "version": "1.0.0",
  "scripts": {
    "infra": "docker compose -f docker-compose.local.yml up -d db redis",
    "infra:test:up": "bash ./scripts/test-env-up.sh",
    "infra:test:down": "bash ./scripts/test-env-down.sh",
    "dev:server": "bash ./scripts/env/with-env.sh local bash -lc 'cd server && air'",
    "dev:admin": "bash ./scripts/env/with-env.sh local bash -lc 'cd admin && npm run dev'",
    "dev:merchant": "bash ./scripts/env/with-env.sh local bash -lc 'cd merchant && npm run dev -- --host'",
    "dev:web": "cd web && VITE_API_URL=http://127.0.0.1:8080/api/v1 VITE_ROUTER_BASENAME=/ npm run dev -- --host 127.0.0.1 --port 5176",
    "dev:user-web:docker": "docker compose -f docker-compose.local.yml up -d db redis api website user-web merchant admin local-gateway",
    "dev:mobile": "cd mobile && npm run web",
    "dev:website": "cd website && npx vite --port 5175",
    "dev:user-web": "npm run infra && npx concurrently -n \"API,WEB\" -c \"magenta,green\" \"npm run dev:server\" \"npm run dev:web\"",
    "dev": "npm run infra && concurrently -n \"API,ADMIN,MERCHANT\" -c \"magenta,blue,green\" \"npm run dev:server\" \"npm run dev:admin\" \"npm run dev:merchant\"",
    "db:check": "bash ./scripts/env/with-env.sh local bash -lc 'cd server && go run ./cmd/dbcheck'",
    "db:cleanup:testdata:local": "bash ./scripts/db-cleanup-tagged-test-data.sh local",
    "db:cleanup:testdata:test": "bash ./scripts/db-cleanup-tagged-test-data.sh test",
    "db:cleanup:testdata:staging": "bash ./scripts/db-cleanup-tagged-test-data.sh staging",
    "gen:tokens": "node shared/design-tokens/scripts/generate-platforms.mjs",
    "check:frontend-style": "node scripts/frontend-style-guard.mjs",
    "check:frontend-style:admin": "node scripts/frontend-style-guard.mjs --scope admin",
    "check:frontend-style:merchant": "node scripts/frontend-style-guard.mjs --scope merchant",
    "check:frontend-style:web": "node scripts/frontend-style-guard.mjs --scope web",
    "check:frontend-style:website": "node scripts/frontend-style-guard.mjs --scope website",
    "check:frontend-style:mini": "node scripts/frontend-style-guard.mjs --scope mini",
    "check:frontend-style:mobile": "node scripts/frontend-style-guard.mjs --scope mobile",
    "fixture:user-web": "./scripts/user-web-fixture.sh",
    "reset:user-web:rate-limit": "./scripts/user-web-clear-rate-limit.sh",
    "smoke:user-web:api": "npm run reset:user-web:rate-limit && ./scripts/user-web-real-api-smoke.sh",
    "verify:user-web": "npm run build:web && npm run fixture:user-web && npm run smoke:user-web:api && npm run test:e2e:user-web && npm run test:e2e:user-web:real",
    "verify:backend": "./scripts/verify-backend.sh",
    "verify:admin": "./scripts/verify-admin.sh",
    "verify:merchant": "./scripts/verify-merchant.sh",
    "verify:web": "./scripts/verify-web.sh",
    "verify:mobile": "./scripts/verify-mobile.sh",
    "verify:mini": "./scripts/verify-mini.sh",
    "verify:ops": "./scripts/verify-ops.sh",
    "smoke:test": "./scripts/smoke-test.sh",
    "smoke:release": "./scripts/smoke-release.sh",
    "regression:nightly": "./scripts/regression-nightly.sh",
    "feishu:bitable:plan": "node scripts/feishu/setup-bitable-issue-base.mjs --dry-run",
    "feishu:bitable:setup": "node scripts/feishu/setup-bitable-issue-base.mjs --create",
    "feishu:bitable:sync": "node scripts/feishu/setup-bitable-issue-base.mjs --sync-existing",
    "feishu:bitable:seed-demo": "node scripts/feishu/seed-bitable-demo.mjs",
    "test:ops": "node --test tests/ops/*.mjs",
    "test:e2e": "npx playwright test",
    "test:e2e:user-web": "WEB_BASE_URL=http://127.0.0.1:5176 npx playwright test -c playwright.user-web.config.ts",
    "test:e2e:user-web:real": "npm run fixture:user-web && npm run reset:user-web:rate-limit && WEB_BASE_URL=http://127.0.0.1:5175 npx playwright test -c playwright.user-web.real.config.ts",
    "test:e2e:merchant:onboarding": "npx playwright test tests/e2e/merchant-onboarding-designer-required-fields.test.ts tests/e2e/merchant-onboarding-foreman-required-fields.test.ts tests/e2e/material-shop-onboarding-required-contact.test.ts tests/e2e/publish-visibility-extended-fields.test.ts",
    "test:e2e:merchant:onboarding:list": "npx playwright test --list tests/e2e/merchant-onboarding-designer-required-fields.test.ts tests/e2e/merchant-onboarding-foreman-required-fields.test.ts tests/e2e/material-shop-onboarding-required-contact.test.ts tests/e2e/publish-visibility-extended-fields.test.ts",
    "test:e2e:merchant:smoke": "npx playwright test tests/e2e/merchant-login-unregistered-redirect.test.ts tests/e2e/merchant-entry-register-foreman.test.ts tests/e2e/merchant-onboarding-designer-rule.test.ts tests/e2e/merchant-onboarding-foreman-rule.test.ts tests/e2e/merchant-onboarding-designer-required-fields.test.ts tests/e2e/merchant-onboarding-foreman-required-fields.test.ts tests/e2e/material-shop-onboarding-products-rule.test.ts tests/e2e/material-shop-onboarding-required-contact.test.ts tests/e2e/publish-visibility-threshold.test.ts tests/e2e/publish-visibility-extended-fields.test.ts tests/e2e/merchant-finance-verification.test.ts tests/e2e/merchant-chat-attachments.test.ts",
    "test:e2e:merchant:smoke:list": "npx playwright test --list tests/e2e/merchant-login-unregistered-redirect.test.ts tests/e2e/merchant-entry-register-foreman.test.ts tests/e2e/merchant-onboarding-designer-rule.test.ts tests/e2e/merchant-onboarding-foreman-rule.test.ts tests/e2e/merchant-onboarding-designer-required-fields.test.ts tests/e2e/merchant-onboarding-foreman-required-fields.test.ts tests/e2e/material-shop-onboarding-products-rule.test.ts tests/e2e/material-shop-onboarding-required-contact.test.ts tests/e2e/publish-visibility-threshold.test.ts tests/e2e/publish-visibility-extended-fields.test.ts tests/e2e/merchant-finance-verification.test.ts tests/e2e/merchant-chat-attachments.test.ts",
    "test:e2e:merchant:ci": "npx playwright test tests/e2e/merchant-login-unregistered-redirect.test.ts tests/e2e/merchant-entry-register-foreman.test.ts tests/e2e/merchant-onboarding-designer-rule.test.ts tests/e2e/merchant-onboarding-foreman-rule.test.ts",
    "test:e2e:merchant:ci:list": "npx playwright test --list tests/e2e/merchant-login-unregistered-redirect.test.ts tests/e2e/merchant-entry-register-foreman.test.ts tests/e2e/merchant-onboarding-designer-rule.test.ts tests/e2e/merchant-onboarding-foreman-rule.test.ts",
    "test:e2e:quote:bridge": "E2E_ADMIN_ORIGIN=http://127.0.0.1:5175/admin MERCHANT_ORIGIN=http://127.0.0.1:5175/merchant E2E_API_BASE_URL=http://127.0.0.1:8080/api/v1 npx playwright test tests/e2e/quote-system-v1.smoke.test.ts",
    "test:e2e:quote:bridge:list": "E2E_ADMIN_ORIGIN=http://127.0.0.1:5175/admin MERCHANT_ORIGIN=http://127.0.0.1:5175/merchant E2E_API_BASE_URL=http://127.0.0.1:8080/api/v1 npx playwright test --list tests/e2e/quote-system-v1.smoke.test.ts",
    "test:e2e:quote:close:fixture": "WEB_BASE_URL=http://127.0.0.1:5175 npx playwright test tests/e2e/user-web-business-closure-flow.test.ts --grep \"项目详情可进入施工报价确认页并完成确认\"",
    "test:e2e:quote:close:fixture:list": "WEB_BASE_URL=http://127.0.0.1:5175 npx playwright test --list tests/e2e/user-web-business-closure-flow.test.ts --grep \"项目详情可进入施工报价确认页并完成确认\"",
    "test:e2e:quote:focused": "npm run test:e2e:quote:bridge && npm run test:e2e:quote:close:fixture",
    "test:e2e:quote:focused:list": "npm run test:e2e:quote:bridge:list && npm run test:e2e:quote:close:fixture:list",
    "test:identity:acceptance": "node scripts/identity-acceptance-runner.mjs",
    "test:identity:acceptance:api": "npx playwright test -c playwright.identity.config.ts --project=identity-api",
    "test:identity:acceptance:ui": "npx playwright test -c playwright.identity.config.ts --project=identity-admin-ui",
    "test:identity:acceptance:report": "node scripts/identity-acceptance-report.mjs",
    "env:print:local": "bash ./scripts/env/with-env.sh local --print",
    "env:print:test": "bash ./scripts/env/with-env.sh test --print",
    "env:print:staging": "bash ./scripts/env/with-env.sh staging --print",
    "env:print:production": "bash ./scripts/env/with-env.sh production --print",
    "dev:mini:h5": "bash ./scripts/env/with-env.sh local bash -lc 'cd mini && npm run dev:h5'",
    "dev:mini:weapp": "bash ./scripts/env/with-env.sh local bash -lc 'cd mini && npm run dev:weapp'",
    "mobile:android:local": "bash ./scripts/env/mobile-run.sh local android",
    "mobile:android:test": "bash ./scripts/env/mobile-run.sh test android",
    "mobile:android:staging": "bash ./scripts/env/mobile-run.sh staging android",
    "mobile:android:production": "bash ./scripts/env/mobile-run.sh production android",
    "mobile:ios:local": "bash ./scripts/env/mobile-run.sh local ios",
    "mobile:ios:test": "bash ./scripts/env/mobile-run.sh test ios",
    "mobile:ios:staging": "bash ./scripts/env/mobile-run.sh staging ios",
    "mobile:ios:production": "bash ./scripts/env/mobile-run.sh production ios",
    "build:admin:staging": "bash ./scripts/env/with-env.sh staging bash -lc 'cd admin && npm run build'",
    "build:admin:production": "bash ./scripts/env/with-env.sh production bash -lc 'cd admin && npm run build'",
    "build:merchant:staging": "bash ./scripts/env/with-env.sh staging bash -lc 'cd merchant && npm run build'",
    "build:merchant:production": "bash ./scripts/env/with-env.sh production bash -lc 'cd merchant && npm run build'",
    "build:web": "cd web && VITE_API_URL=/api/v1 VITE_ROUTER_BASENAME=/ npm run build",
    "build:mini:h5:staging": "bash ./scripts/env/with-env.sh staging bash -lc 'cd mini && npm run build:h5'",
    "build:mini:h5:production": "bash ./scripts/env/with-env.sh production bash -lc 'cd mini && npm run build:h5'",
    "build:mini:weapp:staging": "bash ./scripts/env/with-env.sh staging bash -lc 'cd mini && npm run build:weapp'",
    "build:mini:weapp:production": "bash ./scripts/env/with-env.sh production bash -lc 'cd mini && npm run build:weapp'"
  },
  "dependencies": {
    "@react-native-community/geolocation": "^3.4.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.57.0",
    "@types/node": "^25.0.3",
    "concurrently": "^9.2.1",
    "postcss-scss": "4.0.9",
    "stylelint": "15.10.3",
    "stylelint-config-standard-scss": "11.1.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  },
  "overrides": {
    "brace-expansion": "1.1.13",
    "diff": "4.0.4",
    "minimatch": "3.1.5",
    "picomatch": "2.3.2",
    "yaml": "2.8.3"
  }
}
