# 仅用于测试 / 预发，不要填写生产环境地址。

# 动态扫描目标
USER_WEB_URL=https://test.example.com
ADMIN_URL=https://admin-test.example.com
API_URL=https://api-test.example.com

# 若需要镜像扫描，可填 1 个或多个镜像（逗号分隔）
# SCAN_IMAGES=home-decoration-api:test,home-decoration-web:test

# ZAP baseline 运行时长（分钟）
ZAP_MINUTES=5

# 失败级别仅作记录使用；当前脚本不会因该值中断
ZAP_FAIL_LEVEL=Medium
