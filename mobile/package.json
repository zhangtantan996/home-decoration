{
  "name": "HomeDecorationApp",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "android": "npm run android:setup && react-native run-android",
    "android:setup": "adb reverse tcp:8081 tcp:8081 && adb reverse tcp:8080 tcp:8080 && adb reverse tcp:6060 tcp:6060 || echo 'Warning: adb reverse failed. Make sure device is connected.'",
    "android:clean": "npm run android:setup && cd android && ./gradlew clean && cd .. && react-native run-android",
    "ios": "react-native run-ios",
    "lint": "eslint .",
    "start": "react-native start",
    "test": "jest",
    "web": "echo 'Web build disabled for native-only app. Use android/ios instead.'",
    "build": "echo 'Production build for native apps - use Android Studio or Xcode'",
    "android:local": "bash ../scripts/env/mobile-run.sh local android",
    "android:test": "bash ../scripts/env/mobile-run.sh test android",
    "android:staging": "bash ../scripts/env/mobile-run.sh staging android",
    "android:production": "bash ../scripts/env/mobile-run.sh production android",
    "ios:local": "bash ../scripts/env/mobile-run.sh local ios",
    "ios:test": "bash ../scripts/env/mobile-run.sh test ios",
    "ios:staging": "bash ../scripts/env/mobile-run.sh staging ios",
    "ios:production": "bash ../scripts/env/mobile-run.sh production ios",
    "android:release:staging": "cd android && ENVFILE=.env.staging ./gradlew assembleRelease",
    "android:bundle:staging": "cd android && ENVFILE=.env.staging ./gradlew bundleRelease",
    "android:release:prod": "cd android && ENVFILE=.env.production ./gradlew assembleRelease"
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "^2.2.0",
    "@react-native-clipboard/clipboard": "^1.16.3",
    "@react-native-community/geolocation": "^3.4.0",
    "@react-native-documents/picker": "^11.0.3",
    "@react-native/new-app-screen": "0.83.0",
    "@react-navigation/bottom-tabs": "^7.8.12",
    "@react-navigation/native": "^7.1.25",
    "@react-navigation/native-stack": "^7.8.6",
    "@tencentcloud/chat": "^3.6.2",
    "@tencentcloud/chat-uikit-react-native": "^1.1.0",
    "axios": "^1.13.2",
    "expo-blur": "^15.0.8",
    "expo-linear-gradient": "^15.0.8",
    "expo-modules-core": "~3.0.29",
    "lucide-react": "^0.561.0",
    "lucide-react-native": "^0.562.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-native": "0.83.0",
    "react-native-blob-util": "^0.24.6",
    "react-native-camera-kit": "^16.1.3",
    "react-native-config": "^1.6.1",
    "react-native-image-crop-picker": "^0.51.1",
    "react-native-image-picker": "^8.2.1",
    "react-native-keychain": "^10.0.0",
    "react-native-linear-gradient": "^2.8.3",
    "react-native-nitro-modules": "^0.33.2",
    "react-native-nitro-sound": "^0.2.10",
    "react-native-safe-area-context": "^5.6.2",
    "react-native-screens": "^4.19.0",
    "react-native-svg": "^15.15.1",
    "react-native-web": "^0.21.2",
    "tinode-sdk": "^0.25.1",
    "zustand": "^5.0.9"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@babel/preset-env": "^7.25.3",
    "@babel/runtime": "^7.25.0",
    "@react-native-community/cli": "20.0.0",
    "@react-native-community/cli-platform-android": "20.0.0",
    "@react-native-community/cli-platform-ios": "20.0.0",
    "@react-native/babel-preset": "0.83.0",
    "@react-native/eslint-config": "0.83.0",
    "@react-native/metro-config": "0.83.0",
    "@react-native/typescript-config": "0.83.0",
    "@types/jest": "^29.5.13",
    "@types/react": "^19.2.0",
    "@types/react-test-renderer": "^19.1.0",
    "@vitejs/plugin-react": "^5.1.2",
    "eslint": "^8.19.0",
    "jest": "^29.6.3",
    "prettier": "2.8.8",
    "react-test-renderer": "19.2.0",
    "typescript": "^5.8.3",
    "vite": "^7.3.0"
  },
  "engines": {
    "node": ">=20"
  }
}
