# Tinode IM Configuration
# Copy this file to .env and fill in the actual values
# IMPORTANT: Never commit the actual .env file with real API keys to Git

# Tinode API Key (required)
# This is the API key for authenticating with Tinode server
# Example: AQEAAAABAAD_rAp4DJh05a1HAwFT3A6K (DO NOT use this example in production)
TINODE_API_KEY=your_tinode_api_key_here

# Tinode Server URL (optional, defaults to localhost for development)
TINODE_SERVER_URL=http://localhost:6060
