{
    "name": "nestcraft-website",
    "private": true,
    "version": "1.0.0",
    "type": "module",
    "scripts": {
        "dev": "vite --port 5175",
        "generate:tokens": "node ../shared/design-tokens/scripts/generate-platforms.mjs --scope website",
        "lint:no-emoji": "node ./scripts/check-no-emoji.mjs",
        "lint:style": "node ../scripts/frontend-style-guard.mjs --scope website",
        "check": "npm run generate:tokens && npm run lint:no-emoji && npm run lint:style && npm run build",
        "build": "npm run generate:tokens && vite build",
        "preview": "vite preview"
    },
    "devDependencies": {
        "vite": "^6.3.5"
    },
    "dependencies": {
        "lucide": "^0.575.0"
    }
}
