# ==========================================
# 支付宝沙箱最小联调模板（按当前项目实际配置项整理）
# 文件用途：
# 1. 复制所需字段到根目录 .env 或 server/.env
# 2. 仅用于本地 / 测试环境，禁止直接用于生产
# ==========================================

# ------------------------------------------
# 后端基础运行
# ------------------------------------------
APP_ENV=local
SERVER_HOST=0.0.0.0
SERVER_PORT=8080
SERVER_MODE=debug

# 本地联调可先用 localhost。
# 但如果要完整接收支付宝异步通知，必须改成支付宝可访问的公网地址。
SERVER_PUBLIC_URL=http://localhost:8080

DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USER=postgres
DATABASE_PASSWORD=123456
DATABASE_DBNAME=home_decoration
DATABASE_SSLMODE=disable

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

JWT_SECRET=replace_with_your_local_jwt_secret

# ------------------------------------------
# 支付宝沙箱
# ------------------------------------------
# 必须开启，否则后端会直接返回“支付宝支付未启用”
ALIPAY_ENABLED=true

# 沙箱固定网关
ALIPAY_SANDBOX=true
ALIPAY_GATEWAY_URL=https://openapi-sandbox.dl.alipaydev.com/gateway.do

# 从支付宝沙箱控制台获取
ALIPAY_APP_ID=your_sandbox_app_id

# 填你的“应用私钥”
# 当前项目已支持在 .env 中使用单行 \n 转义形式，例如：
# ALIPAY_APP_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----"
ALIPAY_APP_PRIVATE_KEY=

# 填支付宝提供的“支付宝公钥”
# 同样建议使用单行 \n 转义形式，例如：
# ALIPAY_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----"
ALIPAY_PUBLIC_KEY=

# 留空时，后端会自动回落到：
# ${SERVER_PUBLIC_URL}/api/v1/payments/alipay/notify
#
# 说明：
# 1. 本地只看拉起支付和页面回跳，可以先留空
# 2. 要完整测通支付成功落库，建议显式改成公网地址
#    例如：https://<your-domain>/api/v1/payments/alipay/notify
ALIPAY_NOTIFY_URL=

# Web 端支付结果页
# 当前本地网关对用户侧使用 /app 前缀
ALIPAY_RETURN_URL_WEB=http://localhost:5175/app/payments/result

# H5 若暂未单独部署，可先与 Web 保持一致
ALIPAY_RETURN_URL_H5=http://localhost:5175/app/payments/result

ALIPAY_TIMEOUT_MINUTES=15

# ------------------------------------------
# 本地联调建议
# ------------------------------------------
# 1. 只做本地页面联调：
#    SERVER_PUBLIC_URL=http://localhost:8080
#    ALIPAY_NOTIFY_URL 留空
#
# 2. 做完整支付闭环：
#    SERVER_PUBLIC_URL=https://<公网API域名>
#    ALIPAY_NOTIFY_URL=https://<公网API域名>/api/v1/payments/alipay/notify
#
# 3. 支付宝沙箱还需要：
#    - 沙箱买家账号
#    - 已向支付宝开放平台上传匹配的应用公钥
