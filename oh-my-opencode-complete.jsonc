{
    "$schema": "https://raw.githubusercontent.com/code-yeongyu/oh-my-opencode/master/assets/oh-my-opencode.schema.json",
    // ========================================
    // Google 认证配置
    // ========================================
    // 是否启用 Google OAuth 认证
    // 推荐使用 opencode-antigravity-auth 插件来获得更好的多账户支持
    "google_auth": false,
    // ========================================
    // Claude Code 兼容性配置
    // ========================================
    // 控制是否启用 Claude Code 的各种功能
    "claude_code": {
        "mcp": false, // Model Context Protocol
        "commands": false, // 自定义命令
        "skills": false, // 技能系统
        "agents": false, // Agent 系统
        "hooks": false // 钩子系统
    },
    // ========================================
    // Sisyphus 编排系统配置
    // ========================================
    // 这是 V3 的核心配置，控制 Sisyphus 如何编排各个 Agent
    "sisyphus_agent": {
        // 是否禁用整个 Sisyphus 编排系统
        "disabled": false,
        // 是否启用 OpenCode-Builder（OpenCode 原生的 build agent 重命名版）
        // 默认禁用，因为 Sisyphus 已经提供了更强大的功能
        "default_builder_enabled": false,
        // ⭐ 是否启用 Prometheus (Planner) - 战略规划 Agent
        // 这是你在 UI 中看到的 Planner，强烈推荐启用
        "planner_enabled": true,
        // 是否将默认的 plan agent 降级为子 agent 模式
        // 设为 true 时，Prometheus 将成为主要的规划 Agent
        "replace_plan": true
    },
    // ========================================
    // Git Master 技能配置
    // ========================================
    // 配置 git-master 技能的行为（原子提交、rebase/squash 等）
    "git_master": {
        // 是否在 commit 消息中添加 "Ultraworked with Sisyphus" 脚注
        "commit_footer": true,
        // 是否添加 Co-authored-by: Sisyphus <clio-agent@sisyphuslabs.ai> 信息
        "include_co_authored_by": true
    },
    // ========================================
    // Agent 配置
    // ========================================
    // 为每个 Agent 配置模型、温度、权限等参数
    "agents": {
        // -------------------- 核心编排 Agent --------------------
        // Sisyphus - 主要编排者
        // 角色：工程经理，负责任务分解和协调各个专业 Agent
        // 推荐使用最强大的模型
        "Sisyphus": {
            "model": "google/antigravity-claude-sonnet-4-5",
            //   "model": "claudeRight/claude-sonnet-4-5-20250929"
            "temperature": 0.3 // 较低温度保证稳定性
        },
        // -------------------- 规划相关 Agent --------------------
        // Prometheus (Planner) - 战略规划者
        // 角色：使用 work-planner 方法论进行战略规划
        // ⭐ 这就是你在 UI 中看到的 Planner！
        "Prometheus (Planner)": {
            "model": "google/antigravity-claude-sonnet-4-5",
            //   "model": "claudeRight/claude-sonnet-4-5-20250929"
            "temperature": 0.5 // 中等温度平衡创造性和准确性
        },
        // Metis (Plan Consultant) - 计划顾问
        // 角色：规划前分析，识别隐藏需求和潜在失败点
        // 可选但推荐，能显著提升规划质量
        "Metis (Plan Consultant)": {
            "model": "google/antigravity-claude-sonnet-4-5",
            //   "model": "claudeRight/claude-sonnet-4-5-20250929"
            "temperature": 0.4
        },
        // Momus (Plan Reviewer) - 计划审查者
        // 角色：审查和验证计划的完整性和可行性
        // 可选，用于复杂项目的计划验证
        "Momus (Plan Reviewer)": {
            "model": "google/antigravity-claude-sonnet-4-5",
            //   "model": "claudeRight/claude-sonnet-4-5-20250929"
            "temperature": 0.3
        },
        // -------------------- 专业技术 Agent --------------------
        // Oracle - 架构和调试专家
        // 角色：处理架构设计、复杂调试、性能优化等
        "oracle": {
            "model": "openai/gpt-5.2-codex",
            "temperature": 0.2 // 低温度确保技术准确性
        },
        // Librarian - 文档和代码搜索专家
        // 角色：文档查找、代码库搜索、知识管理
        "librarian": {
            "model": "google/antigravity-claude-sonnet-4-5",
            //   "model": "claudeRight/claude-sonnet-4-5-20250929"
            "temperature": 0.3
        },
        // Explore - 快速代码库探索
        // 角色：基于 grep 的快速代码搜索和分析
        // 推荐使用快速且便宜的模型
        "explore": {
            "model": "claudeRight/claude-haiku-4-5-20251001",
            "temperature": 0.2
        },
        // -------------------- 前端和设计 Agent --------------------
        // Frontend UI/UX Engineer - 前端工程师
        // 角色：UI/UX 设计、前端开发、用户体验优化
        // 使用 Gemini 的视觉和创造力优势
        "frontend-ui-ux-engineer": {
            "model": "google/antigravity-gemini-3-pro",
            "temperature": 0.7 // 较高温度支持创造性设计
        },
        // -------------------- 文档和多模态 Agent --------------------
        // Document Writer - 文档编写专家
        // 角色：技术文档、README、API 文档等
        "document-writer": {
            "model": "google/antigravity-gemini-3-flash",
            "temperature": 0.6
        },
        // Multimodal Looker - 多模态分析
        // 角色：图片分析、截图理解、视觉内容处理
        "multimodal-looker": {
            "model": "google/antigravity-gemini-3-flash",
            "temperature": 0.5
        }
    },
    // ========================================
    // 分类任务委派配置
    // ========================================
    // 根据任务类型自动选择合适的模型
    // 使用 delegate_task(category='xxx') 来触发
    "categories": {
        // 视觉工程 - UI/UX、设计、前端视觉效果
        "visual-engineering": {
            "model": "google/antigravity-gemini-3-pro",
            "temperature": 0.7
        },
        // 艺术创作 - 创意设计、品牌、艺术性内容
        "artistry": {
            "model": "google/antigravity-gemini-3-pro",
            "temperature": 0.8 // 最高温度支持最大创造力
        },
        // 写作 - 文档、博客、营销文案等
        "writing": {
            "model": "google/antigravity-gemini-3-flash",
            "temperature": 0.6
        },
        // 快速任务 - 简单修复、快速实现
        // 推荐用于 git-master 技能：delegate_task(category='quick', skills=['git-master'])
        "quick": {
            "model": "claudeRight/claude-haiku-4-5-20251001",
            "temperature": 0.3
        }
    }
    // ========================================
    // 可选配置项（取消注释以启用）
    // ========================================
    // 禁用特定的内置技能
    // 可用技能: "playwright", "git-master"
    // "disabled_skills": ["playwright"],
    // 禁用特定的 Agent
    // "disabled_agents": ["multimodal-looker"],
    // 禁用特定的钩子（Hooks）
    // 可用钩子: "todo-continuation-enforcer", "context-window-monitor",
    //          "session-recovery", "comment-checker", "think-mode", 
    //          "ralph-loop", "startup-toast" 等
    // "disabled_hooks": ["startup-toast"],
    // 后台任务并发配置
    // "background_tasks": {
    //   "max_concurrent_per_provider": 3,  // 每个提供商的最大并发数
    //   "max_concurrent_per_model": 2      // 每个模型的最大并发数
    // }
}