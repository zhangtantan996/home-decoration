APP_ENV=staging

# Runtime
JWT_SECRET=replace_with_strong_jwt_secret
ENCRYPTION_KEY=replace_with_32_byte_base64_key
TINODE_UID_ENCRYPTION_KEY=replace_with_tinode_uid_key
TINODE_AUTH_TOKEN_KEY=replace_with_tinode_auth_key
TINODE_API_KEY_SALT=replace_with_tinode_api_key_salt

# Public domains
SERVER_PUBLIC_URL=http://api.hezeyunchuang.com
CORS_ALLOWED_ORIGINS=http://hezeyunchuang.com,http://www.hezeyunchuang.com,http://admin.hezeyunchuang.com
VITE_APP_ENV=staging
VITE_API_URL=/api/v1
WEB_PORT=8888
UPLOADS_DIR=../server/uploads

# Managed infrastructure
DATABASE_HOST=replace_with_db_host
DATABASE_PORT=5432
DATABASE_USER=postgres
DATABASE_PASSWORD=replace_with_db_password
DATABASE_DBNAME=home_decoration
DATABASE_SSLMODE=disable
REDIS_HOST=replace_with_redis_host
REDIS_PORT=6379
REDIS_PASSWORD=replace_with_redis_password
REDIS_DB=0
TINODE_DATABASE_DSN=postgres://postgres:replace_with_tinode_db_password@replace_with_db_host:5432/tinode?sslmode=disable

# SMS for pre-launch testing: fixed code mode
SMS_PROVIDER=mock
SMS_REGION_ID=cn-hangzhou
SMS_FIXED_CODE_MODE=true
SMS_FIXED_CODE=123456
SMS_ACCESS_KEY_ID=
SMS_ACCESS_KEY_SECRET=
SMS_SIGN_NAME=
SMS_TEMPLATE_CODE=

# Optional: switch to real SMS before formal launch
# SMS_PROVIDER=aliyun
# SMS_FIXED_CODE_MODE=false
# SMS_ACCESS_KEY_ID=...
# SMS_ACCESS_KEY_SECRET=...
# SMS_SIGN_NAME=...
# SMS_TEMPLATE_CODE=...
