APP_ENV=test

# Test runtime
DB_USER=postgres
DB_PASSWORD=replace_with_test_db_password
DB_NAME=home_decoration_test
REDIS_PASSWORD=replace_with_test_redis_password
REDIS_DB=1
JWT_SECRET=replace_with_test_jwt_secret
ENCRYPTION_KEY=replace_with_test_encryption_key
TINODE_UID_ENCRYPTION_KEY=replace_with_test_tinode_uid_key
TINODE_AUTH_TOKEN_KEY=replace_with_test_tinode_auth_key
TINODE_API_KEY_SALT=replace_with_test_tinode_api_salt

# Test public entrypoints
SERVER_PUBLIC_URL=https://api-test.example.com
CORS_ALLOWED_ORIGINS=https://test.example.com,https://www.test.example.com,https://admin-test.example.com
VITE_APP_ENV=test
VITE_API_URL=/api/v1
WEB_PORT=8889
UPLOADS_DIR=../server/uploads_test

# Host routing hints for deploy/rollback verification
DEPLOY_API_HOST=api-test.example.com
DEPLOY_ADMIN_HOST=admin-test.example.com
DEPLOY_WEBSITE_HOST=test.example.com

# Managed services only (leave empty if using docker-compose.test.yml)
DATABASE_HOST=test-db.example.internal
DATABASE_PORT=5432
DATABASE_USER=postgres
DATABASE_PASSWORD=replace_with_managed_test_db_password
DATABASE_DBNAME=home_decoration_test
DATABASE_SSLMODE=disable
REDIS_HOST=test-redis.example.internal
REDIS_PORT=6379
TINODE_DATABASE_DSN=postgres://postgres:replace_with_tinode_db_password@test-db.example.internal:5432/tinode_test?sslmode=disable

# Optional integrations
SMS_PROVIDER=mock
SMS_ACCESS_KEY_ID=
SMS_ACCESS_KEY_SECRET=
SMS_SIGN_NAME=
SMS_TEMPLATE_CODE=
SMS_REGION_ID=cn-hangzhou
