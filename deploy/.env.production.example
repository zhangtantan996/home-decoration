APP_ENV=production

# Compose-managed database / redis
DB_USER=postgres
DB_PASSWORD=replace_with_prod_db_password
DB_NAME=home_decoration
REDIS_PASSWORD=replace_with_prod_redis_password
REDIS_DB=0

# API runtime
JWT_SECRET=replace_with_strong_jwt_secret
ENCRYPTION_KEY=replace_with_32_byte_base64_key
TINODE_UID_ENCRYPTION_KEY=replace_with_tinode_uid_key
TINODE_AUTH_TOKEN_KEY=replace_with_tinode_auth_key
TINODE_API_KEY_SALT=replace_with_tinode_api_key_salt

# Public entrypoints
SERVER_PUBLIC_URL=https://api.example.com
CORS_ALLOWED_ORIGINS=https://example.com,https://www.example.com,https://admin.example.com
VITE_APP_ENV=production
VITE_API_URL=/api/v1
VITE_PUBLIC_SITE_URL=https://example.com
WEB_PORT=8888
UPLOADS_DIR=../server/uploads

# Routing hints used by deploy/scripts/lib/release_common.sh
DEPLOY_API_HOST=api.example.com
DEPLOY_ADMIN_HOST=admin.example.com
DEPLOY_WEBSITE_HOST=example.com

# Optional managed service config, only needed when production uses managed DB / Redis
DATABASE_HOST=
DATABASE_PORT=5432
DATABASE_USER=postgres
DATABASE_PASSWORD=
DATABASE_DBNAME=home_decoration
DATABASE_SSLMODE=disable
REDIS_HOST=
REDIS_PORT=6379
TINODE_DATABASE_DSN=postgres://postgres:replace_with_tinode_db_password@db.example.internal:5432/tinode?sslmode=disable

# Optional SMS config
SMS_PROVIDER=mock
SMS_ACCESS_KEY_ID=
SMS_ACCESS_KEY_SECRET=
SMS_SIGN_NAME=
SMS_TEMPLATE_CODE=
SMS_REGION_ID=cn-hangzhou
SMS_FIXED_CODE_MODE=false
SMS_FIXED_CODE=
