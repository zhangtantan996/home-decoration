# 环境配置示例
# 复制此文件为 .env 并填入实际值

# 应用环境 (local, docker, production)
APP_ENV=local

# JWT 密钥（必须！使用 openssl rand -base64 64 生成）
# ⚠️ 警告：生产环境必须替换为随机生成的密钥，切勿使用示例值！
# 生成命令: openssl rand -base64 64
JWT_SECRET=REPLACE_WITH_YOUR_GENERATED_SECRET_HERE

# 敏感数据加密密钥（必须！32字节用于AES-256加密）
# 用于加密身份证号、银行卡号等敏感信息
# 生成命令: openssl rand -base64 32
ENCRYPTION_KEY=REPLACE_WITH_YOUR_32_BYTE_KEY_HERE

# 数据库配置
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USER=postgres
DATABASE_PASSWORD=YOUR_SECURE_PASSWORD_HERE
DATABASE_NAME=home_decoration
# 命名建议：
# - local: home_decoration
# - test: home_decoration_test
# - staging: home_decoration_staging
# - production: home_decoration

# Redis配置
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# 服务器配置
SERVER_HOST=0.0.0.0
SERVER_PORT=8080
SERVER_MODE=debug
# 对外可访问的 API 根地址。
# 支付宝 notify_url 与第一跳 return_url 在未显式配置时会回落到这个地址。
# 生产环境示例: https://api.example.com
SERVER_PUBLIC_URL=http://localhost:8080
WECHAT_H5_BASE_PATH=/app

# 通知实时推送（站内通知 WebSocket）
NOTIFICATION_REALTIME_ENABLED=true
NOTIFICATION_WS_MAX_CONN_PER_USER=5
NOTIFICATION_WS_MAX_CONN_PER_IP=50
NOTIFICATION_WS_PING_INTERVAL_SECONDS=30
NOTIFICATION_WS_IDLE_TIMEOUT_SECONDS=90
NOTIFICATION_WS_SEND_BUFFER_SIZE=32

# 支付宝（Web/H5 一期）
# 沙箱网关: https://openapi-sandbox.dl.alipaydev.com/gateway.do
# 生产网关: https://openapi.alipay.com/gateway.do
# 注意:
# 1. .env 建议使用单行 \n 转义形式填写 ALIPAY_APP_PRIVATE_KEY / ALIPAY_PUBLIC_KEY。
# 2. ALIPAY_NOTIFY_URL 留空时，后端会回落到 ${SERVER_PUBLIC_URL}/api/v1/payments/alipay/notify
# 3. ALIPAY_RETURN_URL_WEB / ALIPAY_RETURN_URL_H5 是 API return 二次跳转后的前端结果页。
#    如果 Web 站点部署在 /app，下方应填写 https://<domain>/app/payments/result
ALIPAY_ENABLED=false
ALIPAY_GATEWAY_URL=https://openapi.alipay.com/gateway.do
ALIPAY_APP_ID=
ALIPAY_APP_PRIVATE_KEY=
ALIPAY_PUBLIC_KEY=
ALIPAY_NOTIFY_URL=
ALIPAY_RETURN_URL_WEB=
ALIPAY_RETURN_URL_H5=
ALIPAY_TIMEOUT_MINUTES=15
ALIPAY_SANDBOX=false

# 数据库目标安全防呆
# 默认不要设置；仅在明确知道自己在做什么时，才允许临时设置为 1 绕过数据库环境安全检查
ALLOW_UNSAFE_DB_TARGET=0

# CORS 白名单（逗号分隔）
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# 短信与验证码风控
SMS_PROVIDER=mock
SMS_ACCESS_KEY_ID=
SMS_ACCESS_KEY_SECRET=
SMS_SIGN_NAME=
SMS_TEMPLATE_CODE=
SMS_TEMPLATE_CODE_LOW=
SMS_TEMPLATE_CODE_MEDIUM=
SMS_TEMPLATE_CODE_HIGH=
SMS_TEMPLATE_CODE_LOGIN=
SMS_TEMPLATE_CODE_REGISTER=
SMS_TEMPLATE_CODE_IDENTITY_APPLY=
SMS_TEMPLATE_CODE_MERCHANT_WITHDRAW=
SMS_TEMPLATE_CODE_MERCHANT_BANK_BIND=
SMS_TEMPLATE_CODE_CHANGE_PHONE=
SMS_TEMPLATE_CODE_DELETE_ACCOUNT=
SMS_REGION_ID=cn-hangzhou
SMS_DEBUG_BYPASS=false
SMS_RISK_ENABLED=true
SMS_CODE_MAX_ATTEMPTS=5
SMS_PHONE_DAILY_LIMIT=10
SMS_IP_DAILY_LIMIT=20
SMS_CAPTCHA_ENABLED=false
SMS_CAPTCHA_PROVIDER=turnstile
SMS_CAPTCHA_VERIFY_URL=
SMS_CAPTCHA_SECRET_KEY=
SMS_CAPTCHA_TIMEOUT_MS=3000
SMS_CAPTCHA_MIN_SCORE=0.0
