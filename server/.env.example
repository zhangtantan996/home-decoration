# 环境配置示例
# 复制此文件为 .env 并填入实际值

# 应用环境 (local, docker, production)
APP_ENV=local

# JWT 密钥（必须！使用 openssl rand -base64 64 生成）
JWT_SECRET=TE5zufBZn5hgu6vryJs8ROC0Y9jm49HotZPFmN+qv1X/aUYK2TEkj61E+1rRTUtwehbOD1ZHLqpRxpbEXrtjbw==

# 数据库配置
