# 装修设计一体化平台 - 服务端配置

server:
  host: "0.0.0.0"
  port: "8080"
  mode: "debug"  # debug | release

database:
  host: "localhost"
  port: "5432"
  user: "postgres"
  password: "your_password"
  dbname: "home_decoration"
  sslmode: "disable"

redis:
  host: "localhost"
  port: "6379"
  password: ""
  db: 0

jwt:
  secret: "your-jwt-secret-key-change-in-production"
  expire_hour: 72

# 阿里云OSS配置 (可选)
oss:
  endpoint: ""
  access_key_id: ""
  access_key_secret: ""
  bucket: ""

# 短信服务配置 (可选)
sms:
  provider: "aliyun"  # aliyun | tencent
  access_key_id: ""
  access_key_secret: ""
  sign_name: ""
  template_code: ""

# 地图服务配置
map:
  provider: "amap"  # amap | baidu
  api_key: ""
